---
interface Phase {
  name: string;
  seconds: number;
  tooltip?: string;
}

interface Bar {
  label: string;
  phases: Phase[];
}

interface Props {
  bars: Bar[];
  maxSeconds?: number;
  showLegend?: boolean;
}

const { bars, maxSeconds: maxSecondsProp, showLegend = true } = Astro.props;

const COLORS: Record<string, string> = {
  'Container start': '#7a8a7a',
  'Python imports': '#5b7b9a',
  'HF config + tokenizer': '#6b9aaa',
  'Weight loading': '#8faa6e',
  'FlashInfer autotune + DeepGEMM': '#c4956a',
  'FlashInfer autotune': '#c4956a',
  'CUDA graph capture': '#a07eb5',
  'Server warmup': '#cc7e7e',
  'Container setup': '#7a8a7a',
  'CRIU process restore': '#6b8a9a',
  'CRIU + CUDA plugin': '#6b8a9a',
  'CUDA plugin': '#a07eb5',
  'Weight reload': '#8faa6e',
  'Wake + reload': '#8faa6e',
};

const hasFractionalTiming = bars.some((bar) =>
  bar.phases.some((phase) => !Number.isInteger(phase.seconds))
);

function formatSeconds(seconds: number): string {
  if (!hasFractionalTiming) {
    return `${Math.round(seconds)}s`;
  }
  return `${seconds.toFixed(1)}s`;
}

const maxSeconds = maxSecondsProp ?? Math.max(...bars.map(b => b.phases.reduce((sum, p) => sum + p.seconds, 0)));
const allPhaseNames = [...new Set(bars.flatMap(b => b.phases.map(p => p.name)))];
---

<div class="startup-breakdown">
  {bars.map((bar) => {
    const total = bar.phases.reduce((sum, p) => sum + p.seconds, 0);
    return (
      <div class="bar-group">
        <div class="bar-header">
          <span class="bar-label">{bar.label}</span>
          <span class="bar-total">{formatSeconds(total)}</span>
        </div>
        <div class="bar-row">
          <div class="bar-track">
            {bar.phases.map((phase) => {
              const pct = (phase.seconds / maxSeconds) * 100;
              const color = COLORS[phase.name] ?? '#999';
              const tip = phase.tooltip ?? `${phase.name}: ${phase.seconds}s`;
              return (
                <div
                  class="phase-segment"
                  style={`width: ${pct}%; background-color: ${color};`}
                  data-tooltip={tip}
                />
              );
            })}
          </div>
        </div>
      </div>
    );
  })}

  {showLegend && (
    <div class="legend">
      {allPhaseNames.map((name) => {
        const color = COLORS[name] ?? '#999';
        return (
          <div class="legend-item">
            <span class="legend-swatch" style={`background-color: ${color};`} />
            <span class="legend-label">{name}</span>
          </div>
        );
      })}
    </div>
  )}

  <div class="phase-tooltip"></div>
</div>

<style>
  .startup-breakdown {
    --sb-text: var(--color-foreground, #0c0c0c);
    --sb-text-muted: color-mix(in srgb, var(--sb-text) 55%, transparent);
    --sb-track-bg: color-mix(in srgb, var(--sb-text) 6%, transparent);
    --sb-tip-bg: #2b2b2b;
    --sb-tip-text: #f5f5f5;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    max-width: 100%;
    margin: 1.5rem 0;
  }

  :global(.dark) .startup-breakdown {
    --sb-text: var(--color-foreground-dark, #fafafa);
    --sb-tip-bg: #f5f5f5;
    --sb-tip-text: #1a1a1a;
  }

  .bar-group {
    margin-bottom: 0.875rem;
  }

  .bar-group:last-of-type {
    margin-bottom: 0;
  }

  .bar-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.2rem;
    gap: 0.75rem;
  }

  .bar-label {
    font-size: 0.8125rem;
    color: var(--sb-text);
    white-space: nowrap;
  }

  .bar-total {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sb-text);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .bar-row {
    display: flex;
    align-items: center;
  }

  .bar-track {
    flex: 1;
    display: flex;
    height: 2.25rem;
    border-radius: 2px;
    overflow: hidden;
    background: var(--sb-track-bg);
  }

  .phase-segment {
    height: 100%;
    cursor: pointer;
    transition: opacity 0.15s;
    min-width: 1px;
  }

  .phase-segment:hover {
    opacity: 0.75;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.125rem 1.25rem;
    margin-top: 1rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .legend-swatch {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .legend-label {
    font-size: 0.6875rem;
    color: var(--sb-text);
    white-space: nowrap;
  }

  .phase-tooltip {
    display: none;
    position: absolute;
    background: var(--sb-tip-bg);
    color: var(--sb-tip-text);
    padding: 6px 10px;
    border-radius: 4px;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    line-height: 1.4;
    max-width: 320px;
    pointer-events: none;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }
</style>

<script>
  document.querySelectorAll('.startup-breakdown').forEach(container => {
    const tooltip = container.querySelector('.phase-tooltip') as HTMLElement;
    if (!tooltip) return;

    // tooltip needs positioned ancestor
    (container as HTMLElement).style.position = 'relative';

    const segments = container.querySelectorAll('.phase-segment');
    let activeSegment: Element | null = null;
    let isTouch = false;

    function showTooltip(segment: Element) {
      const text = segment.getAttribute('data-tooltip');
      if (!text) return;

      tooltip.textContent = text;
      tooltip.style.display = 'block';

      const containerRect = container.getBoundingClientRect();
      const segmentRect = segment.getBoundingClientRect();

      let left = segmentRect.left - containerRect.left + segmentRect.width / 2;
      let top = segmentRect.bottom - containerRect.top + 8;

      const tipWidth = tooltip.offsetWidth;
      left = Math.max(8, Math.min(left - tipWidth / 2, containerRect.width - tipWidth - 8));

      tooltip.style.left = left + 'px';
      tooltip.style.top = top + 'px';

      if (activeSegment && activeSegment !== segment) {
        (activeSegment as HTMLElement).style.opacity = '1';
      }
      (segment as HTMLElement).style.opacity = '0.75';
      activeSegment = segment;
    }

    function hideTooltip() {
      tooltip.style.display = 'none';
      if (activeSegment) {
        (activeSegment as HTMLElement).style.opacity = '1';
        activeSegment = null;
      }
    }

    segments.forEach(seg => {
      seg.addEventListener('mouseenter', () => {
        if (!isTouch) showTooltip(seg);
      });
      seg.addEventListener('mouseleave', () => {
        if (!isTouch) hideTooltip();
      });

      seg.addEventListener('touchstart', (e) => {
        isTouch = true;
        e.preventDefault();
        if (activeSegment === seg) {
          hideTooltip();
        } else {
          showTooltip(seg);
        }
      }, { passive: false });
    });

    document.addEventListener('touchstart', (e) => {
      if (!container.contains(e.target as Node)) hideTooltip();
    });
    document.addEventListener('click', (e) => {
      if (!container.contains(e.target as Node)) hideTooltip();
    });
  });
</script>
